	$(MAKE) -f SG-SLAM/ros/semgraph_slam/loopclosure/CMakeFiles/loopclosure.dir/build.make SG-SLAM/ros/semgraph_slam/loopclosure/CMakeFiles/loopclosure.dir/build
.PHONY : loopclosure/fast

#=============================================================================
# Target rules for targets named pipeline

# Build rule for target.
pipeline: cmake_check_build_system
	$(MAKE) -f CMakeFiles/Makefile2 pipeline
.PHONY : pipeline

# fast build rule for target.
pipeline/fast:
	$(MAKE) -f SG-SLAM/ros/semgraph_slam/pipeline/CMakeFiles/pipeline.dir/build.make SG-SLAM/ros/semgraph_slam/pipeline/CMakeFiles/pipeline.dir/build
.PHONY : pipeline/fast

